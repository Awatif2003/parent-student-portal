# ShuleYangu Family Portal (parents & students) — environment variables.
# Copy this file to .env and fill in your values. NEVER commit .env.

# ── Backend API ────────────────────────────────────────────────────────────
# Base URL of the ShuleYangu Django REST API. MUST end in /api/v1 — the axios
# client appends paths like /auth/login/ and /attendance/parent/children/ onto
# this, so a bare /api will 404.
#   Development:  http://192.168.100.18:8001/api/v1
#   Production:   https://api.shuleyangu.com/api/v1
VITE_API_URL=http://192.168.100.18:8001/api/v1
